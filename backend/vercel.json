{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{tests/**,storage/**,tmp/**,.pytest_cache/**,scripts/**,infra/**,alembic/**,docker-compose.yml,**/__pycache__/**}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
