rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRequired(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function optionalString(data, field, maxLen) {
      return !(field in data) || data[field] == null || (data[field] is string && data[field].size() <= maxLen);
    }

    function optionalBool(data, field) {
      return !(field in data) || data[field] == null || data[field] is bool;
    }

    function optionalStringList(data, field, maxItems) {
      return !(field in data) || data[field] == null || (data[field] is list && data[field].size() <= maxItems);
    }

    function validEmail(email) {
      return email is string && email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$');
    }

    function immutable(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function validUser(data) {
      return hasRequired(['uid', 'email', 'createdAt']) &&
        data.uid == request.auth.uid &&
        validEmail(data.email) &&
        data.createdAt is timestamp &&
        optionalString(data, 'displayName', 80) &&
        optionalString(data, 'photoURL', 1000) &&
        optionalString(data, 'backendUserId', 128) &&
        optionalString(data, 'grade', 40) &&
        optionalString(data, 'track', 80) &&
        optionalString(data, 'career', 500) &&
        optionalString(data, 'targetUniversity', 120) &&
        optionalString(data, 'targetMajor', 120) &&
        optionalString(data, 'admissionType', 120) &&
        optionalStringList(data, 'interestUniversities', 20) &&
        optionalBool(data, 'marketingAgreed') &&
        (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function validOwnedDocument(data) {
      return hasRequired(['id', 'userId', 'title', 'createdAt']) &&
        data.userId == request.auth.uid &&
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 200 &&
        data.createdAt is timestamp &&
        optionalString(data, 'type', 80) &&
        optionalString(data, 'subject', 120) &&
        optionalString(data, 'content', 100000) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function validChatSession(data) {
      return hasRequired(['id', 'userId', 'createdAt']) &&
        data.userId == request.auth.uid &&
        data.createdAt is timestamp &&
        optionalString(data, 'title', 200) &&
        optionalString(data, 'documentId', 128) &&
        (!('messages' in data) || data.messages is list && data.messages.size() <= 1000) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && validUser(request.resource.data);
      allow update: if isOwner(userId) && validUser(request.resource.data) && immutable(['uid', 'createdAt']);
      allow delete: if false;
    }

    match /documents/{documentId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && validOwnedDocument(request.resource.data);
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        validOwnedDocument(request.resource.data) &&
        immutable(['id', 'userId', 'createdAt']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /chatSessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && validChatSession(request.resource.data);
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        validChatSession(request.resource.data) &&
        immutable(['id', 'userId', 'createdAt']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
